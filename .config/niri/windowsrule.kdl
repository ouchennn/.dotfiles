// Global window styling (applies to all windows)
window-rule {
    // Corner rounding for modern appearance
    // Set to 0 for sharp corners, or try 8-12 for rounded
    geometry-corner-radius 0
    
    // Clip window contents to match rounded corners
    // Prevents content from overflowing rounded boundaries
    clip-to-geometry true
}

window-rule {
    match app-id="kitty"
    draw-border-with-background false
    opacity 0.95
}

window-rule {
  match app-id="impala-tui"
  match title="bluetui-pop"
  open-floating true
  default-column-width { proportion 0.5; }
  default-window-height { fixed 500; }

}

window-rule {
    match app-id=r#"firefox"#
    open-maximized true
}

window-rule {
    match app-id=r#"obsidian$"#
    open-maximized true
}

// Firefox picture-in-picture player
// Open as floating window rather than tiled
window-rule {
    // Matches both regular and Flatpak Firefox
    // Regular: app-id="firefox"
    // Flatpak: app-id="org.mozilla.firefox"
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

window-rule {
    match app-id="steam" title=r#"^notificationtoasts_\d+_desktop$"#
    default-floating-position x=10 y=10 relative-to="bottom-right"
}

window-rule {
    match title=r#".*(Properties|Preferences|Settings|Configuration).*"#
    open-floating true
}

window-rule {
    match title=r#".*Open.*|.*Save.*|.*Choose.*"#
    open-floating true
    default-column-width { proportion 0.0; }
    max-width 900
    max-height 800
}

// Example: Block password managers from screen capture (commented out)
// Prevents passwords from appearing in screenshots or screencasts
window-rule {
    match app-id=r#"^org\.keepassxc\.KeePassXC$"#
    // block-out-from "screen-capture"  - Blocks from all capture (screenshots + screencasts)
    // block-out-from "screencast"      - Blocks only from screencasts (allows screenshots)
    block-out-from "screen-capture"
}


