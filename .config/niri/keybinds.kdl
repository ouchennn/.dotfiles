binds {
    Mod+Ctrl+P { show-hotkey-overlay; } 
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; } //what does this do ?
    Mod+Shift+E { spawn "rofi" "-show" "p" "-modi" "p:/home/ucef/.config/rofi/power-menu.sh --no-symbols" "-theme" "/home/ucef/.config/rofi/power-menu.rasi"; }
    Mod+Shift+C hotkey-overlay-title="Open Clipboard History" { spawn "sh" "-c" "cliphist list | rofi -dmenu -p 'Clipboard' | cliphist decode | wl-copy"; }

    Mod+Return hotkey-overlay-title="Open Terminal" { spawn "kitty"; }
    Mod+Space hotkey-overlay-title="Run Application" { spawn "rofi" "-show" "drun"; }

    Mod+Q repeat=false { close-window; }
    Mod+V { toggle-window-floating;}  
    Mod+Shift+V { switch-focus-between-floating-and-tiling; }
    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; } // real fullscreen
    Mod+W { toggle-column-tabbed-display; }

    
    // Focus navigation - vim-style HJKL keys
    Mod+H { focus-column-left; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }
    Mod+L { focus-column-right; }
    
    // Focus navigation - arrow keys (for when vim keys feel awkward)
    Mod+Left { focus-column-left; }
    Mod+Down { focus-window-down; }
    Mod+Up { focus-window-up; }
    Mod+Right { focus-column-right; }
    
    // Move windows within workspace
    Mod+Ctrl+H { move-column-left; }
    Mod+Ctrl+J { move-window-down; }
    Mod+Ctrl+K { move-window-up; }
    Mod+Ctrl+L { move-column-right; }
    
    Mod+Ctrl+Left { move-column-left; }
    Mod+Ctrl+Down { move-window-down; }
    Mod+Ctrl+Up { move-window-up; }
    Mod+Ctrl+Right { move-column-right; }
    
    // Jump to column extremes. what are home and ENd ? wtf ? 
    Mod+Home { focus-column-first; } 
    Mod+End { focus-column-last; }
    Mod+Ctrl+Home { move-column-to-first; }
    Mod+Ctrl+End { move-column-to-last; }

    // Consume and expel windows from columns
    Mod+BracketLeft { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }
    Mod+Comma { consume-window-into-column; }
    Mod+Period { expel-window-from-column; }
    
    // Column and window sizing
    Mod+R { switch-preset-column-width; }
    Mod+Shift+R { switch-preset-window-height; }
    Mod+Ctrl+R { reset-window-height; }
    Mod+Ctrl+F { expand-column-to-available-width; }
    
    // Fine-grained size adjustments
    // Note: Mod+Minus conflicts with workspace 6 on AZERTY, so commented out
    // Use Mod+R for preset width switching instead
    Mod+alt+Minus { set-column-width "-9%"; }
    Mod+alt+Equal { set-column-width "+10%"; }
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }
    
    // Column centering. How to make it centered by default ? for the first window to open
    Mod+C { center-column; }
    Mod+Ctrl+C { center-visible-columns; }

    // Direct workspace access using AZERTY number row (symbols without Shift)
    // These are the physical keys above QWERTY on your keyboard
    Mod+ampersand { focus-workspace 1; }     // & key
    Mod+eacute { focus-workspace 2; }        // é key
    Mod+quotedbl { focus-workspace 3; }      // " key
    Mod+apostrophe { focus-workspace 4; }    // ' key
    Mod+parenleft { focus-workspace 5; }     // ( key
    Mod+minus { focus-workspace 6; }         // - key
    Mod+egrave { focus-workspace 7; }        // è key
    Mod+underscore { focus-workspace 8; }    // _ key
    Mod+ccedilla { focus-workspace 9; }      // ç key
    
    // Relative workspace navigation (often more convenient than direct access)
    Mod+U { focus-workspace-down; }
    Mod+I { focus-workspace-up; }
    Mod+Page_Down { focus-workspace-down; }
    Mod+Page_Up { focus-workspace-up; }
    
    // Workspace reordering
    Mod+Shift+U { move-workspace-down; }
    Mod+Shift+I { move-workspace-up; }
    Mod+Shift+Page_Down { move-workspace-down; }
    Mod+Shift+Page_Up { move-workspace-up; }
    
    // Mouse wheel workspace navigation
    Mod+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp cooldown-ms=150 { focus-workspace-up; }

    // Move column to workspace using Ctrl + AZERTY symbols
    // Using Ctrl instead of Shift because Shift+symbol gives numbers on AZERTY
    Mod+Ctrl+ampersand { move-column-to-workspace 1; }
    Mod+Ctrl+eacute { move-column-to-workspace 2; }
    Mod+Ctrl+quotedbl { move-column-to-workspace 3; }
    Mod+Ctrl+apostrophe { move-column-to-workspace 4; }
    Mod+Ctrl+parenleft { move-column-to-workspace 5; }
    Mod+Ctrl+minus { move-column-to-workspace 6; }
    Mod+Ctrl+egrave { move-column-to-workspace 7; }
    Mod+Ctrl+underscore { move-column-to-workspace 8; }
    Mod+Ctrl+ccedilla { move-column-to-workspace 9; }
    
    // Relative workspace movement for windows
    Mod+Ctrl+U { move-column-to-workspace-down; }
    Mod+Ctrl+I { move-column-to-workspace-up; }
    Mod+Ctrl+Page_Down { move-column-to-workspace-down; }
    Mod+Ctrl+Page_Up { move-column-to-workspace-up; }
    
    // Mouse wheel for moving windows between workspaces
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp cooldown-ms=150 { move-column-to-workspace-up; }
     
    // Focus different monitors
    Mod+Shift+H { focus-monitor-left; }
    Mod+Shift+J { focus-monitor-down; }
    Mod+Shift+K { focus-monitor-up; }
    Mod+Shift+L { focus-monitor-right; }
    
    Mod+Shift+Left { focus-monitor-left; }
    Mod+Shift+Down { focus-monitor-down; }
    Mod+Shift+Up { focus-monitor-up; }
    Mod+Shift+Right { focus-monitor-right; }
    
    // Move columns between monitors
    Mod+Shift+Ctrl+H { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+J { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+K { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+L { move-column-to-monitor-right; }
    
    Mod+Shift+Ctrl+Left { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+Down { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+Up { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+Right { move-column-to-monitor-right; }

    // Horizontal scrolling through columns
    Mod+WheelScrollRight { focus-column-right; }
    Mod+WheelScrollLeft { focus-column-left; }
    Mod+Ctrl+WheelScrollRight { move-column-right; }
    Mod+Ctrl+WheelScrollLeft { move-column-left; }
    
    // Shift+wheel for horizontal scrolling (common convention)
    Mod+Shift+WheelScrollDown { focus-column-right; }
    Mod+Shift+WheelScrollUp { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp { move-column-left; }
    
    Mod+O repeat=false { toggle-overview; }
    Print { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print { screenshot-window; }

    // Audio volume controls
    XF86AudioRaiseVolume allow-when-locked=true { 
        spawn "/home/ucef/.local/bin/hardware-ctl.sh" "volume" "up"; 
    }
    XF86AudioLowerVolume allow-when-locked=true { 
        spawn "/home/ucef/.local/bin/hardware-ctl.sh" "volume" "down"; 
    }
    XF86AudioMute allow-when-locked=true { 
        spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; 
    }
    XF86AudioMicMute allow-when-locked=true { 
        spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; 
    }
    
    // Screen brightness controls
    XF86MonBrightnessUp allow-when-locked=true { 
        spawn "/home/ucef/.local/bin/hardware-ctl.sh" "brightness" "up"; 
    }
    XF86MonBrightnessDown allow-when-locked=true { 
        spawn "/home/ucef/.local/bin/hardware-ctl.sh" "brightness" "down"; 
    }
    //Fn+Space
    XF86WakeUp allow-when-locked=true {
      spawn "/home/ucef/bin/test.sh" "kdb_backlight" "show";

    }
     // ============================================================================
    // REPURPOSED THINKPAD FUNCTION KEYS (F7-F12)
    // ============================================================================
    
    // Function keys F7-F12 on ThinkPad T14 send specialized XF86 signals.
    // Since these original purposes aren't useful for typical desktop use,
    // we're repurposing them for practical everyday functions.
    
    // F7 - Display management (XF86Display)
    // TODO: Add display management when needed
    // Options to consider:
    //  - wdisplays (install from AUR: yay -S wdisplays)
    //  - nwg-displays (available in repos: sudo pacman -S nwg-displays)
    // For now, leaving unbound since external display use is infrequent
    // XF86Display { spawn "nwg-displays"; }
    
    // F8 - Network management (XF86WLAN)
    // Using nm-connection-editor for graphical network control
    // Install: sudo pacman -S network-manager-applet
    // Also add nm-applet to your spawn-at-startup section for system tray integration
    // Turns off wifi completely :()
    //XF86WLAN { spawn "nm-connection-editor"; }
    
    // F9 - Notification management (XF86NotificationCenter)
    // TODO: Configure notification system (mako recommended for minimal Wayland setup)
    // Install: sudo pacman -S mako
    // Add to spawn-at-startup: command "mako"
    // This binding restores the last dismissed notification for re-reading
    // XF86NotificationCenter { spawn "makoctl" "restore"; }
    
    // F10 - Media play/pause (XF86PickupPhone)
    // Conceptually "picking up" starts the media, just like answering starts a call
    XF86HangupPhone { spawn "playerctl" "next"; }
    
    // F12 - Favorites (XF86Favorites)
    // Firefox already handles this for bookmarks, so leaving it unbound
    // The browser will capture this key before niri sees it
    // If you want to override browser behavior, uncomment and set a custom action:
    // XF86Favorites { spawn "your-command-here"; }
    
    Super+Alt+S allow-when-locked=true hotkey-overlay-title=null { 
        spawn-sh "pkill orca || exec orca"; 
    }
}
