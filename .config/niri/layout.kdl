layout {
    gaps 20
    center-focused-column "never"

    // Preset column widths for Mod+R cycling
    // These are proportions of screen width after accounting for gaps
    preset-column-widths {
        proportion 0.33333  // One third of screen
        proportion 0.5      // Half of screen
        proportion 0.66667
        proportion 1.0
      }
    // Mod+Shift+R
    preset-window-heights {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }    
    default-column-width { proportion 0.5; }  

    focus-ring {
        width 4
        active-gradient from="#cc0e13" to="#2b0000" angle=45
        inactive-gradient from="#505050" to="#808080" angle=45 relative-to="workspace-view"
    }
    
    // Drop shadows: subtle depth effect for windows
    shadow {
        on
        softness 2
        spread 8
        offset x=7 y=7
        // Shadow color and opacity
        // Format: #RRGGBBAA where AA is alpha (00=transparent, FF=opaque)
        color "#0007"  // Black at ~4% opacity
    }
    border{
      off
    }
    // Struts: reserved space at screen edges
    // Shrinks window area to prevent overlap with panels or docks
    // Values in logical pixels
    struts {
        left 0
        right 0
        top 0      // Reserve space for top status bar
        bottom 0   // Reserve space for bottom dock
    }
    background-color "transparent"
}

